{
  "name": "cuiabar-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:ssr && node scripts/generate-seo-assets.mjs",
    "build:blog": "vite build --config vite.config.blog.ts && npm run build:ssr:blog && node scripts/generate-blog-assets.mjs",
    "build:ssr": "vite build --ssr src/ssr/render.tsx --outDir .ssr --emptyOutDir",
    "build:ssr:blog": "vite build --ssr src/blog/ssr/render.tsx --outDir .ssr-blog --emptyOutDir",
    "bootstrap:blog-cms": "node scripts/bootstrap-directus-blog-schema.mjs",
    "sync:blog-content": "node scripts/sync-blog-content-from-directus.mjs",
    "sync:blog-content:cloudflare": "node scripts/sync-blog-content-from-cloudflare-native.mjs",
    "blogger:auth": "node scripts/authorize-blogger.mjs",
    "blogger:auth:manual": "node scripts/manual-blogger-auth.mjs",
    "blogger:list": "node scripts/list-blogger-blogs.mjs",
    "blogger:theme:prepare": "node scripts/prepare-blogger-theme-upload.mjs",
    "blogger:theme:upload-ui": "node scripts/upload-blogger-theme-file.mjs",
    "blogger:publish": "node scripts/publish-to-blogger.mjs",
    "build:worker": "tsc -p tsconfig.worker.json",
    "preview": "vite preview",
    "lint": "tsc --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "perf:check": "node scripts/check-performance-budgets.mjs",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name=cuiabar-site",
    "deploy:blog": "npm run build:blog && wrangler pages deploy dist-blog --project-name=cuiabar-blog",
    "build:blog:cms": "npm run sync:blog-content && npm run build:blog",
    "build:blog:cloudflare": "npm run sync:blog-content:cloudflare && npm run build:blog",
    "deploy:blog:cms": "npm run sync:blog-content && npm run deploy:blog",
    "deploy:blog:cloudflare": "npm run sync:blog-content:cloudflare && npm run deploy:blog",
    "deploy:worker": "npm run build && wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply cuiabar_crm --local",
    "d1:migrate:remote": "wrangler d1 migrations apply cuiabar_crm --remote"
  },
  "dependencies": {
    "hono": "^4.12.7",
    "jose": "^6.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^4.71.0"
  }
}
