{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "meta-ads-actions",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-04",
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "meta-ads-actions.cuiabar.com",
      "custom_domain": true
    }
  ],
  "vars": {
    "META_GRAPH_API_VERSION": "v25.0"
  }
}
